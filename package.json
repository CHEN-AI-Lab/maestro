{
  "name": "saas-starter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@saas-starter/web",
    "dev:web:alt": "cd apps/web && npx next dev",
    "build": "prisma generate && turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "format": "prettier --write .",
    "db:generate": "cd apps/web && npx prisma generate",
    "db:push": "cd apps/web && npx prisma db push",
    "db:studio": "cd apps/web && npx prisma studio"
  },
  "devDependencies": {
    "prettier": "^3",
    "prisma": "5.22.0",
    "turbo": "^2"
  },
  "packageManager": "pnpm@10.28.0",
  "dependencies": {
    "@prisma/client": "5.22.0"
  }
}